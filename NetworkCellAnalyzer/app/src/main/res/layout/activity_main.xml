<?xml version="1.0" encoding="utf-8"?>
<!--
    Main screen layout:
    - Shows real-time cell information (operator, signal, network type, etc.)
    - Has a server IP input field so the user can point to their server
    - Start/Stop button to control the monitoring service
    - Button to open the Statistics screen
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Network Cell Analyzer"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!-- Server IP configuration -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server URL (e.g. http://192.168.1.100:5000)"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://four51-project.onrender.com"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Demo mode toggle (useful for testing on emulators) -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchDemoMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Demo Mode (simulated cell data)"
            android:layout_marginBottom="8dp" />

        <!-- Start / Stop button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Monitoring"
            android:layout_marginBottom="8dp" />

        <!-- View Statistics button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Statistics"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <!-- Status indicator -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Stopped"
            android:textSize="14sp"
            android:textColor="@color/signal_bad"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- Real-time Cell Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Real-Time Cell Information"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Signal power chart (custom view, shows last 20 samples) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Signal Power Over Time"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp" />
                <com.eece451.networkcellanalyzer.SignalChartView
                    android:id="@+id/signalChart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginBottom="12dp" />

                <!-- Network quality grade badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network Quality"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvQualityGrade"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="-"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="#9E9E9E" />
                </LinearLayout>

                <!-- Operator -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Operator"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvOperator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Network Type -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Network Type"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvNetworkType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Signal Power -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Signal Power"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvSignalPower"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-- dBm"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- SINR / SNR -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SINR / SNR"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvSinr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-- dB"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Cell ID -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cell ID"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvCellId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Frequency Band -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Frequency Band"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvFrequencyBand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Timestamp -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last Updated"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
